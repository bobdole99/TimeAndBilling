@model Project

<h1> Add new project </h1>

<form method="post" asp-action="Add" role="form">
    
    <partial name="_ProjectCard" />
    
    <div class="row">
        <div class="col-md-offset-2 col-md-6">
            <input type="submit" class="btn btn-primary" value="Add" />
        </div>
        <div class="col-md-offset-2 col-md-6">
            <input type="submit" class="btn btn-primary" asp-controller="Project" asp-action="Cancel" value="Cancel" />
        </div>
    </div>
</form>
